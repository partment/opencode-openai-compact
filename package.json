{
  "name": "opencode-openai-compact",
  "version": "1.1.1",
  "description": "OpenCode plugin that stores OpenAI Responses API compaction checkpoints in SQLite.",
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "configSchema.json",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "openai",
    "compact"
  ],
  "author": "PartMent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/partment/opencode-openai-compact.git"
  },
  "bugs": {
    "url": "https://github.com/partment/opencode-openai-compact/issues"
  },
  "homepage": "https://github.com/partment/opencode-openai-compact#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=22.12.0",
    "opencode": ">=1.3.8"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.17.8",
    "jsonc-parser": "3.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
